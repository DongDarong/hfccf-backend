APP_NAME=hfccf-backend
APP_ENV=testing
APP_KEY=base64:QUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUE=
APP_DEBUG=false
APP_URL=http://hfccf-backend.test
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hfccf_backend_testing
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
FILESYSTEM_IMAGE_DISK=r2
FILESYSTEM_IMAGE_LEGACY_DISKS=public
R2_ACCESS_KEY_ID=testing-r2-access-key
R2_SECRET_ACCESS_KEY=testing-r2-secret-key
R2_BUCKET=testing-bucket
R2_ENDPOINT=https://example.invalid
R2_PUBLIC_URL=https://example.invalid
R2_REGION=auto
QUEUE_CONNECTION=sync

CACHE_STORE=array

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=array
MAIL_HOST=smtp.example.invalid
MAIL_PORT=587
MAIL_USERNAME=testing@example.com
MAIL_PASSWORD=testing-mail-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=testing@example.com
MAIL_FROM_NAME="HFCCF"

AWS_ACCESS_KEY_ID=testing-aws-access-key
AWS_SECRET_ACCESS_KEY=testing-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=testing-bucket
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
