APP_NAME=hfccf-backend
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://hfccf-backend.test
PRESCHOOL_PDF_BROWSER_PATH=
# Comma-separated list of allowed frontend origins for CORS.
# Local dev:   FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173
# Staging:     FRONTEND_URLS=https://staging.hfccf.org
# Production:  FRONTEND_URLS=https://hfccf.org
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hfccf_backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Sanctum personal access token expiration in minutes (null = never).
# 720 = 12 hours (default short session); 43200 = 30 days (remember-me).
SANCTUM_EXPIRATION=720

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Keep image uploads on the public disk locally; switch to r2 in production.
FILESYSTEM_IMAGE_DISK=public
FILESYSTEM_IMAGE_LEGACY_DISKS=public
# Cloudflare R2 (S3-compatible) image storage.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_REGION=auto
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Production SMTP example (Gmail):
# MAIL_MAILER=smtp
# MAIL_SCHEME=tls
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-address@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM_ADDRESS="no-reply@hfccf.org"
# MAIL_FROM_NAME="HFCCF"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
